{
    "compilerOptions": {
      "composite": true,
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "allowImportingTsExtensions": true,
      "isolatedModules": true,
      "noEmit": true,
      "skipLibCheck": true,
      "strict": true,
      "esModuleInterop": true,
      "types": ["node"],
      "baseUrl": ".",
      "paths": {
        "@/*": ["./src/*"]
      }
    },
    "include": ["src/main/**/*", "src/preload/**/*"],
    "exclude": ["src/renderer/**/*"]
  }
  